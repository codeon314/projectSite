---
import { marked } from 'marked';
import Layout from '../../layouts/Layout.astro';
import { fetchAndCache } from '../../lib/cache.js';

export async function getStaticPaths() {
  const projectModules = import.meta.glob('/src/content/projects/*.json', { eager: true });
  const projects = Object.values(projectModules).map((m: any) => m.default || m);

  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

let readmeContent = '# README could not be fetched.';
if (project.repoLink) {
  const readmeUrl = `${project.repoLink}/raw/branch/main/README.md`;
  readmeContent = await fetchAndCache(readmeUrl);
}

const parsedReadme = marked.parse(readmeContent);
---
<Layout title={project.projectName}>
    <main class="project-detail">
        <div class="top-bar">
            <a href="/projects" class="back-link">&larr; Back to Projects</a>
            <div class="meta-actions">
                <span class="version-badge">Latest: {project.latestRelease}</span>
                <a href={project.repoLink} target="_blank" class="repo-link">View Source &rarr;</a>
            </div>
        </div>
        
        <article set:html={parsedReadme} />
    </main>
</Layout>

<style>
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
    flex-wrap: wrap;
    gap: 1rem;
  }
  .back-link {
    color: #9CA3AF;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .back-link:hover {
    color: var(--accent-color);
    text-decoration: underline;
  }
  .meta-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .version-badge {
    font-size: 0.85rem;
    color: #9CA3AF;
    background-color: var(--card-bg);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
  }
  .repo-link { 
    background-color: var(--card-bg); 
    padding: 0.4rem 1rem; 
    border-radius: 6px; 
    border: 1px solid var(--border-color); 
    text-align: center; 
    font-size: 0.9rem;
    color: var(--text-color);
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .repo-link:hover { 
    border-color: var(--accent-color); 
    color: var(--accent-color);
  }
  
  /* Ensure the first H1 from the markdown doesn't have a massive top gap */
  article :global(h1:first-of-type) {
    margin-top: 0;
  }
  article :global(h1), article :global(h2) { 
    border-bottom: 1px solid var(--border-color); 
    padding-bottom: 0.5rem; 
  }
  
  @media (max-width: 768px) {
    .top-bar { 
      flex-direction: column; 
      align-items: flex-start; 
    }
    .meta-actions { 
      width: 100%; 
      justify-content: space-between; 
    }
  }
</style>