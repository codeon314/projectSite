---
import { getCollection } from 'astro:content';
import { promises as fs } from 'fs';
import path from 'path';
import { marked } from 'marked';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog'); 
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

// 1. Grab the loaded JSON post data straight from props
const { post } = Astro.props;
const postData = post.data;

// 2. Read and parse the corresponding dynamic markdown file cleanly
const readmeContent = await fs.readFile(
  path.join(process.cwd(), 'src/content/blog_readmes', postData.readmePath),
  'utf-8'
).catch(() => '# Post content not found');

const parsedReadme = marked.parse(readmeContent);
---
<Layout title={postData.title}>
  <main class="post-detail">
    <a href="/blog" class="back-link">&larr; Back to Blog</a>
    <h1>{postData.title}</h1>
    <div class="meta">
      <span><strong>Published:</strong> {new Date(postData.date).toDateString()}</span>
    </div>
    <hr />
    <article set:html={parsedReadme} />
  </main>
</Layout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: #9CA3AF;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .back-link:hover {
    color: var(--accent-color);
    text-decoration: underline;
  }
  .post-detail .meta {
    margin: 1rem 0;
    color: #9CA3AF;
  }
  article :global(h1), article :global(h2) {
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }
  article :global(pre) {
    background-color: var(--card-bg);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
  }
</style>
