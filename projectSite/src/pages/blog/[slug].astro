---
import { promises as fs } from 'fs';
import path from 'path';
import { marked } from 'marked';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogDir = path.join(process.cwd(), 'src/content/blog');
  const blogFilenames = await fs.readdir(blogDir);
  
  const posts = await Promise.all(
    blogFilenames
      .filter(file => file.endsWith('.json'))
      .map(async (file) => {
        const filePath = path.join(blogDir, file);
        const fileContent = await fs.readFile(filePath, 'utf-8');
        return JSON.parse(fileContent);
      })
  );

  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

// 1. Grab the loaded JSON post data straight from props
const { post } = Astro.props;

// 2. Read and parse the corresponding dynamic markdown file cleanly
const readmeContent = await fs.readFile(
  path.join(process.cwd(), 'src/content/blog_readmes', post.readmePath),
  'utf-8'
).catch(() => '# Post content not found');

const parsedReadme = marked.parse(readmeContent);
---
<Layout title={post.title}>
  <main class="post-detail">
    <div class="top-bar">
        <a href="/blog" class="back-link">&larr; Back to Blog</a>
        <div class="meta-actions">
            <span class="date-badge">Published: {new Date(post.date).toDateString()}</span>
        </div>
    </div>
    
    <article set:html={parsedReadme} />
  </main>
</Layout>

<style>
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
    flex-wrap: wrap;
    gap: 1rem;
  }
  .back-link {
    color: #9CA3AF;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .back-link:hover {
    color: var(--accent-color);
    text-decoration: underline;
  }
  .meta-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .date-badge {
    font-size: 0.85rem;
    color: #9CA3AF;
    background-color: var(--card-bg);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
  }
  
  /* Ensure the first H1 from the markdown doesn't have a massive top gap */
  article :global(h1:first-of-type) {
    margin-top: 0;
  }
  article :global(h1), article :global(h2) {
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }
  
  @media (max-width: 768px) {
    .top-bar { 
      flex-direction: column; 
      align-items: flex-start; 
    }
    .meta-actions { 
      width: 100%; 
      justify-content: flex-start; 
    }
  }
</style>