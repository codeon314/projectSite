---
import { marked } from 'marked';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const postModules = import.meta.glob('/src/content/blog/*.json', { eager: true });
  const posts = Object.values(postModules).map((m: any) => m.default || m);

  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

// 1. Grab the loaded JSON post data straight from props
const { post } = Astro.props;

// 2. Read the corresponding dynamic markdown file using Vite's import.meta.glob
// The '?raw' query tells Vite to import the file as a raw string
const readmes = import.meta.glob('/src/content/blog_readmes/*.md', { query: '?raw', import: 'default', eager: true });
const readmeKey = `/src/content/blog_readmes/${post.readmePath}`;
const readmeContent = (readmes[readmeKey] as string) || '# Post content not found';

const parsedReadme = marked.parse(readmeContent);
---
<Layout title={post.title}>
  <main class="post-detail">
    <div class="top-bar">
        <a href="/blog" class="back-link">&larr; Back to Blog</a>
        <div class="meta-actions">
            <span class="date-badge">Published: {new Date(post.date).toDateString()}</span>
        </div>
    </div>
    
    <article set:html={parsedReadme} />

    <hr class="divider" />
    
    <section class="comments-section">
      <h2>Terminal Logs</h2>
      
      <form id="comment-form" class="comment-form" data-slug={post.slug}>
        <div class="input-group">
          <label for="username">User ID</label>
          <input type="text" id="username" name="username" placeholder="guest_user" required maxlength="50" />
        </div>
        <div class="input-group">
          <label for="comment-text">Log Entry</label>
          <textarea id="comment-text" name="text" placeholder="Enter your transmission here..." required maxlength="500" rows="3"></textarea>
        </div>
        <button type="submit" class="submit-btn" id="submit-btn">Submit Log</button>
      </form>

      <div id="comments-container" class="comments-container">
        <div class="loading-text">Fetching logs...</div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
    flex-wrap: wrap;
    gap: 1rem;
  }
  .back-link {
    color: #9CA3AF;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .back-link:hover {
    color: var(--accent-color);
    text-decoration: underline;
  }
  .meta-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .date-badge {
    font-size: 0.85rem;
    color: #9CA3AF;
    background-color: var(--card-bg);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
  }
  
  /* Ensure the first H1 from the markdown doesn't have a massive top gap */
  article :global(h1:first-of-type) {
    margin-top: 0;
  }
  article :global(h1), article :global(h2) {
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }
  
  @media (max-width: 768px) {
    .top-bar { 
      flex-direction: column; 
      align-items: flex-start; 
    }
    .meta-actions { 
      width: 100%; 
      justify-content: flex-start; 
    }
  }

  /* --- Comments Section Styles --- */
  .divider {
    border: 0;
    height: 1px;
    background: var(--border-color);
    margin: 3rem 0;
  }
  .comments-section h2 {
    color: var(--accent-color);
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }
  .comment-form {
    background-color: var(--card-bg);
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    margin-bottom: 2rem;
  }
  .input-group {
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .input-group label {
    color: #9CA3AF;
    font-size: 0.9rem;
    font-family: monospace;
  }
  .input-group input, .input-group textarea {
    background-color: #000000;
    border: 1px solid var(--border-color);
    color: var(--text-color);
    padding: 0.8rem;
    border-radius: 4px;
    font-family: inherit;
    transition: border-color 0.2s ease;
  }
  .input-group input:focus, .input-group textarea:focus {
    outline: none;
    border-color: var(--accent-color);
  }
  .submit-btn {
    background-color: var(--accent-color);
    color: #000000;
    border: none;
    padding: 0.8rem 1.5rem;
    border-radius: 4px;
    font-weight: bold;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    font-family: monospace;
    text-transform: uppercase;
  }
  .submit-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 0 10px rgba(0, 229, 255, 0.4);
  }
  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .comments-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .comment-card {
    background-color: #050505;
    border-left: 3px solid var(--accent-color);
    padding: 1rem;
    border-radius: 0 4px 4px 0;
  }
  .comment-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .comment-author {
    color: var(--accent-color);
    font-weight: bold;
    font-family: monospace;
  }
  .comment-author::before {
    content: "> ";
  }
  .comment-date {
    color: #6B7280;
  }
  .comment-body {
    color: #D1D5DB;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .empty-comments, .loading-text {
    color: #9CA3AF;
    font-style: italic;
    font-family: monospace;
  }
  .error-text {
    color: #FF5F56;
    font-family: monospace;
  }
</style>

<script>
  function setupComments() {
    const form = document.getElementById('comment-form');
    const container = document.getElementById('comments-container');
    if (!form || !container) return;

    // Clone and replace to prevent duplicate event listeners from ViewTransitions
    const newForm = form.cloneNode(true);
    form.replaceWith(newForm);
    const activeForm = document.getElementById('comment-form');

    const slug = activeForm.dataset.slug;

    async function loadComments() {
      try {
        const res = await fetch(`/api/comments/${slug}`);
        if (!res.ok) throw new Error('Failed to fetch');
        const comments = await res.json();
        
        container.innerHTML = '';
        if (comments.length === 0) {
          container.innerHTML = '<p class="empty-comments">No logs found. Be the first to transmit.</p>';
          return;
        }

        comments.forEach(c => {
          const div = document.createElement('div');
          div.className = 'comment-card';
          const date = new Date(c.date).toLocaleString();
          div.innerHTML = `
            <div class="comment-header">
              <span class="comment-author">${c.username}</span>
              <span class="comment-date">${date}</span>
            </div>
            <div class="comment-body">${c.text}</div>
          `;
          container.appendChild(div);
        });
      } catch (err) {
        container.innerHTML = '<p class="error-text">Error establishing connection to log server.</p>';
      }
    }

    activeForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submit-btn');
      const usernameInput = document.getElementById('username') as HTMLInputElement;
      const textInput = document.getElementById('comment-text') as HTMLTextAreaElement;
      
      const username = usernameInput.value.trim();
      const text = textInput.value.trim();
      if (!username || !text) return;

      btn.disabled = true;
      btn.textContent = 'Transmitting...';

      try {
        const res = await fetch(`/api/comments/${slug}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, text })
        });

        if (!res.ok) throw new Error('Failed to post');
        
        textInput.value = '';
        await loadComments();
      } catch (err) {
        alert('Transmission failed. Please try again.');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Submit Log';
      }
    });

    // Initial load
    loadComments();
  }

  // Run on initial load and after Astro ViewTransitions
  document.addEventListener('astro:page-load', setupComments);
</script>