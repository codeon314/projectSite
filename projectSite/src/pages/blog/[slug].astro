---
import { marked } from 'marked';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const postModules = import.meta.glob('/src/content/blog/*.json', { eager: true });
  const posts = Object.values(postModules).map((m: any) => m.default || m);

  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

// 1. Grab the loaded JSON post data straight from props
const { post } = Astro.props;

// 2. Read the corresponding dynamic markdown file using Vite's import.meta.glob
// The '?raw' query tells Vite to import the file as a raw string
const readmes = import.meta.glob('/src/content/blog_readmes/*.md', { query: '?raw', import: 'default', eager: true });
const readmeKey = `/src/content/blog_readmes/${post.readmePath}`;
const readmeContent = (readmes[readmeKey] as string) || '# Post content not found';

const parsedReadme = marked.parse(readmeContent);
---
<Layout title={post.title}>
  <main class="post-detail">
    <div class="top-bar">
        <a href="/blog" class="back-link">&larr; Back to Blog</a>
        <div class="meta-actions">
            <span class="date-badge">Published: {new Date(post.date).toDateString()}</span>
        </div>
    </div>
    
    <article set:html={parsedReadme} />

    <hr class="divider" />
    
    <section class="comments-section">
      <div class="comments-header-row">
        <h2>Terminal Logs</h2>
        <span id="comments-count" class="comments-count">0 Transmissions</span>
      </div>

      <div id="comments-container" class="comments-container">
        <div class="loading-text">Fetching logs...</div>
      </div>
      
      <div class="form-wrapper">
        <h3 class="form-title">Initialize Transmission</h3>
        <form id="comment-form" class="comment-form" data-slug={post.slug}>
          <div class="input-group">
            <label for="username">User ID</label>
            <input type="text" id="username" name="username" placeholder="guest_user" required maxlength="50" />
          </div>
          <div class="input-group">
            <label for="comment-text">Log Entry</label>
            <textarea id="comment-text" name="text" placeholder="Enter your transmission here..." required maxlength="1000" rows="3"></textarea>
            <span id="char-counter" class="char-counter">0/1000</span>
          </div>
          <button type="submit" class="submit-btn" id="submit-btn">Submit Log</button>
        </form>
      </div>
    </section>

    <!-- Custom Toast Overlay -->
    <div id="toast-overlay" class="toast-overlay">
      <div class="toast-content">
        <span class="toast-icon">⚠️</span>
        <span id="toast-message">System Notification</span>
      </div>
    </div>

    <!-- Lightbox Overlay -->
    <div id="lightbox-overlay" class="lightbox-overlay">
      <img id="lightbox-img" class="lightbox-img" src="" alt="Expanded view" />
    </div>
  </main>
</Layout>

<style>
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
    flex-wrap: wrap;
    gap: 1rem;
  }
  .back-link {
    color: #9CA3AF;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .back-link:hover {
    color: var(--accent-color);
    text-decoration: underline;
  }
  .meta-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .date-badge {
    font-size: 0.85rem;
    color: #9CA3AF;
    background-color: var(--card-bg);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
  }
  
  /* Ensure the first H1 from the markdown doesn't have a massive top gap */
  article :global(h1:first-of-type) {
    margin-top: 0;
  }
  article :global(h1), article :global(h2) {
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }

  /* --- Markdown Image Auto-Scaling & Styling --- */
  article :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    cursor: zoom-in;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    display: block;
    margin: 2rem auto;
    border: 1px solid var(--border-color);
  }
  
  article :global(img:hover) {
    transform: scale(1.02);
    box-shadow: 0 4px 15px rgba(0, 229, 255, 0.2);
    border-color: var(--accent-color);
  }
  
  @media (max-width: 768px) {
    .top-bar { 
      flex-direction: column; 
      align-items: flex-start; 
    }
    .meta-actions { 
      width: 100%; 
      justify-content: flex-start; 
    }
  }

  /* --- Comments Section Styles --- */
  .divider {
    border: 0;
    height: 1px;
    background: var(--border-color);
    margin: 3rem 0;
  }
  
  .comments-header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }

  .comments-header-row h2 {
    color: var(--accent-color);
    margin: 0;
    font-size: 1.5rem;
    border: none;
    padding: 0;
  }

  .comments-count {
    font-family: monospace;
    color: #9CA3AF;
    background-color: var(--card-bg);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    border: 1px solid var(--border-color);
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .comments-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  /* 
    CRITICAL FIX: We must use :global() for classes generated by JavaScript, 
    otherwise Astro's scoped CSS will ignore them!
  */
  .comments-container :global(.comment-card) {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    animation: fadeIn 0.5s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .comments-container :global(.comment-avatar) {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: var(--accent-color);
    color: #000000;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.5rem;
    font-family: monospace;
    flex-shrink: 0;
    box-shadow: 0 0 15px rgba(0, 229, 255, 0.2);
    border: 2px solid #000000;
  }

  .comments-container :global(.comment-content) {
    flex-grow: 1;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
    /* Ensure long unbroken strings don't overflow the box on mobile */
    min-width: 0; 
  }

  .comments-container :global(.comment-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .comments-container :global(.comment-author) {
    color: var(--accent-color);
    font-weight: bold;
    font-family: monospace;
    font-size: 1.1rem;
    word-break: break-all;
  }

  .comments-container :global(.comment-date) {
    color: #6B7280;
    font-size: 0.9rem;
    font-family: monospace;
  }

  .comments-container :global(.comment-body) {
    color: #D1D5DB;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
    font-size: 1rem;
  }

  .comments-container :global(.empty-comments), 
  .comments-container :global(.loading-text) {
    color: #9CA3AF;
    font-style: italic;
    font-family: monospace;
    text-align: center;
    padding: 3rem 0;
    background-color: var(--card-bg);
    border-radius: 8px;
    border: 1px dashed var(--border-color);
  }

  .comments-container :global(.error-text) {
    color: #FF5F56;
    font-family: monospace;
    text-align: center;
    padding: 2rem 0;
  }

  /* --- Form Styles --- */
  .form-wrapper {
    background-color: var(--card-bg);
    padding: 2rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    border-top: 3px solid var(--accent-color);
  }

  .form-title {
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: var(--text-color);
    font-family: monospace;
    font-size: 1.2rem;
  }

  .comment-form {
    display: flex;
    flex-direction: column;
  }

  .input-group {
    margin-bottom: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .input-group label {
    color: #9CA3AF;
    font-size: 0.9rem;
    font-family: monospace;
  }

  .char-counter {
    color: #9CA3AF;
    font-size: 0.85rem;
    font-family: monospace;
    align-self: flex-end;
  }

  .input-group input, .input-group textarea {
    background-color: #000000;
    border: 1px solid var(--border-color);
    color: var(--text-color);
    padding: 0.8rem;
    border-radius: 4px;
    font-family: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  /* Disable resizing on the textarea */
  .input-group textarea {
    resize: none;
  }

  .input-group input:focus, .input-group textarea:focus {
    outline: none;
    border-color: var(--accent-color);
    box-shadow: 0 0 5px rgba(0, 229, 255, 0.2);
  }

  /* Validation Highlight Styles */
  .input-group input.invalid, .input-group textarea.invalid {
    border-color: #FF5F56 !important;
    box-shadow: 0 0 5px rgba(255, 95, 86, 0.4) !important;
  }

  /* Override Chrome/Webkit Autofill styling to maintain dark theme */
  .input-group input:-webkit-autofill,
  .input-group input:-webkit-autofill:hover, 
  .input-group input:-webkit-autofill:focus, 
  .input-group textarea:-webkit-autofill,
  .input-group textarea:-webkit-autofill:hover,
  .input-group textarea:-webkit-autofill:focus {
    -webkit-text-fill-color: var(--text-color) !important;
    -webkit-box-shadow: 0 0 0px 1000px #000000 inset !important;
    transition: background-color 5000s ease-in-out 0s;
  }

  /* Ensure the cyan glow still works when an autofilled input is focused */
  .input-group input:-webkit-autofill:focus,
  .input-group textarea:-webkit-autofill:focus {
    border-color: var(--accent-color) !important;
    -webkit-box-shadow: 0 0 0px 1000px #000000 inset, 0 0 5px rgba(0, 229, 255, 0.2) !important;
  }

  .submit-btn {
    background-color: var(--accent-color);
    color: #000000;
    border: none;
    padding: 0.8rem 1.5rem;
    border-radius: 4px;
    font-weight: bold;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    font-family: monospace;
    text-transform: uppercase;
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .submit-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 0 10px rgba(0, 229, 255, 0.4);
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* --- Custom Toast Overlay Styles --- */
  .toast-overlay {
    position: fixed;
    top: 20px;
    right: 20px;
    background-color: #0A0A0A;
    border: 1px solid #1A1A1A;
    border-left: 4px solid #FF5F56; /* Red accent for alerts */
    color: #EDEDED;
    padding: 1rem 1.5rem;
    border-radius: 6px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.8);
    z-index: 9999;
    transform: translateX(150%);
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    font-family: monospace;
    max-width: 350px;
  }

  .toast-overlay.show {
    transform: translateX(0);
  }

  .toast-content {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .toast-icon {
    font-size: 1.2rem;
  }

  /* --- Lightbox Styles --- */
  .lightbox-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(5px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .lightbox-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-img {
    max-width: 95vw;
    max-height: 95vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8);
    transform: scale(0.95);
    transition: transform 0.3s ease;
    cursor: zoom-out;
  }

  .lightbox-overlay.is-open .lightbox-img {
    transform: scale(1);
  }

  @media (max-width: 600px) {
    /* Removed the flex-direction: column override for .comment-card so it stays side-by-side */
    .submit-btn {
      align-self: stretch;
    }
    .toast-overlay {
      top: 10px;
      right: 10px;
      left: 10px;
      max-width: none;
    }
  }
</style>

<script>
  // Generates a robust SHA-256 hardware/browser fingerprint
  async function generateFingerprint() {
    const components = [
      navigator.userAgent,
      navigator.language,
      screen.colorDepth,
      screen.width + 'x' + screen.height,
      Intl.DateTimeFormat().resolvedOptions().timeZone,
      navigator.hardwareConcurrency || 'unknown',
      navigator.deviceMemory || 'unknown'
    ].join('|');

    const msgBuffer = new TextEncoder().encode(components);
    const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
  }

  // Custom Toast Notification Logic
  let toastTimeout;
  function showToast(message) {
    const toast = document.getElementById('toast-overlay');
    const toastMsg = document.getElementById('toast-message');
    if (!toast || !toastMsg) return;

    toastMsg.textContent = message;
    toast.classList.add('show');

    if (toastTimeout) clearTimeout(toastTimeout);
    toastTimeout = setTimeout(() => {
      toast.classList.remove('show');
    }, 4000);
  }

  function setupLightbox() {
    const overlay = document.getElementById('lightbox-overlay');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const articleImages = document.querySelectorAll('article img');

    if (!overlay || !lightboxImg) return;

    // Clone and replace to prevent duplicate event listeners from ViewTransitions
    const newOverlay = overlay.cloneNode(true);
    overlay.replaceWith(newOverlay);
    const activeOverlay = document.getElementById('lightbox-overlay');
    const activeLightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

    articleImages.forEach(img => {
      img.addEventListener('click', () => {
        activeLightboxImg.src = (img as HTMLImageElement).src;
        activeOverlay.classList.add('is-open');
      });
    });

    activeOverlay.addEventListener('click', () => {
      activeOverlay.classList.remove('is-open');
      setTimeout(() => {
        activeLightboxImg.src = ''; // Clear src after transition to prevent ghost images
      }, 300);
    });
  }

  function setupComments() {
    const form = document.getElementById('comment-form');
    const container = document.getElementById('comments-container');
    const countDisplay = document.getElementById('comments-count');
    if (!form || !container || !countDisplay) return;

    // Clone and replace to prevent duplicate event listeners from ViewTransitions
    const newForm = form.cloneNode(true);
    form.replaceWith(newForm);
    const activeForm = document.getElementById('comment-form') as HTMLFormElement;

    const slug = activeForm.dataset.slug;
    let currentCommentCount = -1;

    // Clear any existing polling interval from previous page visits
    if ((window as any).commentPollInterval) {
      clearInterval((window as any).commentPollInterval);
    }

    // Attach input listeners to clear validation highlights and update char counter in real-time
    const usernameInput = document.getElementById('username') as HTMLInputElement;
    const textInput = document.getElementById('comment-text') as HTMLTextAreaElement;
    const charCounter = document.getElementById('char-counter');
    
    if (usernameInput) {
      usernameInput.addEventListener('input', () => usernameInput.classList.remove('invalid'));
    }
    if (textInput) {
      textInput.addEventListener('input', () => {
        textInput.classList.remove('invalid');
        if (charCounter) {
          charCounter.textContent = `${textInput.value.length}/1000`;
        }
      });
    }

    async function loadComments(isBackgroundPoll = false) {
      try {
        // Force the browser to bypass all caches (disk, memory, and network)
        const res = await fetch(`/api/comments/${slug}?t=${Date.now()}`, {
          method: 'GET',
          cache: 'no-store',
          headers: {
            'Cache-Control': 'no-store, no-cache, must-revalidate, proxy-revalidate',
            'Pragma': 'no-cache',
            'Expires': '0'
          }
        });
        
        if (!res.ok) throw new Error('Failed to fetch');
        const comments = await res.json();
        
        // Smart DOM Updating: Only rebuild HTML if the number of comments changed
        if (comments.length === currentCommentCount) return;
        currentCommentCount = comments.length;

        container.innerHTML = '';
        
        // Update the counter
        countDisplay.textContent = `${comments.length} Transmission${comments.length === 1 ? '' : 's'}`;
        
        // Flash the counter slightly to indicate an update occurred
        if (isBackgroundPoll) {
          countDisplay.style.color = 'var(--accent-color)';
          setTimeout(() => countDisplay.style.color = '#9CA3AF', 1000);
        }

        if (comments.length === 0) {
          container.innerHTML = '<div class="empty-comments">No logs found. Be the first to transmit.</div>';
          return;
        }

        comments.forEach(c => {
          const div = document.createElement('div');
          div.className = 'comment-card';
          
          const dateOptions: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' };
          const date = new Date(c.date).toLocaleDateString(undefined, dateOptions);
          
          // Extract first letter for avatar
          const initial = c.username ? c.username.charAt(0).toUpperCase() : '?';

          div.innerHTML = `
            <div class="comment-avatar">${initial}</div>
            <div class="comment-content">
              <div class="comment-header">
                <span class="comment-author">${c.username}</span>
                <span class="comment-date">${date}</span>
              </div>
              <div class="comment-body">${c.text}</div>
            </div>
          `;
          container.appendChild(div);
        });
      } catch (err) {
        if (!isBackgroundPoll) {
          container.innerHTML = '<div class="error-text">Error establishing connection to log server.</div>';
        }
      }
    }

    activeForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      
      let rawUsername = usernameInput.value.trim();
      let rawText = textInput.value.trim();

      // Strict Regex Patterns
      const usernameRegex = /^[a-zA-Z0-9\s]+$/;
      const textRegex = /^[a-zA-Z0-9\s.,!?'-]+$/;

      let isValid = true;

      // Validate Username
      if (!rawUsername || !usernameRegex.test(rawUsername)) {
        usernameInput.classList.add('invalid');
        isValid = false;
      } else {
        usernameInput.classList.remove('invalid');
      }

      // Validate Text
      if (!rawText || !textRegex.test(rawText)) {
        textInput.classList.add('invalid');
        isValid = false;
      } else {
        textInput.classList.remove('invalid');
      }

      // Block submission and alert user if illegal characters are found
      if (!isValid) {
        showToast("Illegal characters detected. Please remove them to transmit.");
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Transmitting...';

      try {
        const fingerprint = await generateFingerprint();

        const res = await fetch(`/api/comments/${slug}`, {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'X-Client-Fingerprint': fingerprint
          },
          body: JSON.stringify({ username: rawUsername, text: rawText })
        });

        if (!res.ok) {
          if (res.status === 429 || res.status === 400) {
            const errData = await res.json();
            throw new Error(errData.error);
          }
          throw new Error('Failed to post');
        }
        
        textInput.value = '';
        if (charCounter) charCounter.textContent = '0/1000';
        await loadComments();
      } catch (err: any) {
        showToast(err.message || 'Transmission failed. Please try again.');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Submit Log';
      }
    });

    // Initial load
    loadComments();

    // Start background polling every 1 second (Near-Instant)
    // We check visibilityState so we don't spam the server if the user switches tabs!
    (window as any).commentPollInterval = setInterval(() => {
      if (document.visibilityState === 'visible') {
        loadComments(true);
      }
    }, 1000);
  }

  // Run on initial load and after Astro ViewTransitions
  document.addEventListener('astro:page-load', () => {
    setupComments();
    setupLightbox();
  });

  // Clean up the polling interval when navigating away to prevent memory leaks
  document.addEventListener('astro:before-preparation', () => {
    if ((window as any).commentPollInterval) {
      clearInterval((window as any).commentPollInterval);
    }
  });
</script>