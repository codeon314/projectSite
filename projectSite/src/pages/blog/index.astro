---
import Layout from '../../layouts/Layout.astro';

const postModules = import.meta.glob('/src/content/blog/*.json', { eager: true });
const posts = Object.values(postModules).map((m: any) => {
  const post = m.default || m;
  return { ...post, date: new Date(post.date) };
});

// Default build-time sort (Newest first)
// The client-side script will handle dynamic sorting later
posts.sort((a, b) => b.date.getTime() - a.date.getTime());
---
<Layout title="Blog | Mastercodeon">
  <main>
    <div class="header-container">
      <h1>Blog</h1>
      <div class="sort-options">
        <span>Sort by:</span>
        <button class="sort-btn active" data-sort="newest">Newest</button>
        <button class="sort-btn" data-sort="oldest">Oldest</button>
      </div>
    </div>
    
    <div class="post-grid">
      {posts.map(post => (
        <!-- We embed the timestamp in data-date so JS can sort it easily -->
        <a href={`/blog/${post.slug}`} class="post-card" data-date={post.date.getTime()}>
          <h3>{post.title}</h3>
          <p>{post.description}</p>
          <span>{post.date.toDateString()}</span>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .header-container h1 {
    margin: 0;
    border-bottom: none;
    padding-bottom: 0;
  }

  .sort-options {
    display: flex;
    align-items: center;
  }

  .sort-btn {
    background: none;
    border: none;
    font-size: 1rem;
    font-family: inherit;
    cursor: pointer;
    margin-left: 1rem;
    color: #9CA3AF;
    padding: 0;
    transition: color 0.2s ease;
  }

  .sort-btn:hover {
    color: var(--text-color);
  }

  .sort-btn.active {
    color: var(--accent-color);
    font-weight: bold;
  }

  .post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .post-card {
    background-color: var(--card-bg);
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    transition: transform 0.2s ease, border-color 0.2s ease;
    display: block;
  }

  .post-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent-color);
  }

  .post-card h3 {
    margin-top: 0;
    color: var(--accent-color);
    margin-bottom: 0.5rem;
  }

  .post-card p {
    color: #D1D5DB;
    margin-bottom: 1rem;
  }

  .post-card span {
    font-size: 0.85rem;
    color: #9CA3AF;
  }
</style>

<script>
  function setupSorting() {
    const grid = document.querySelector('.post-grid');
    if (!grid) return;

    // Check URL for initial sort state (if someone shares a link with ?sort=oldest)
    const params = new URLSearchParams(window.location.search);
    const initialSort = params.get('sort') || 'newest';

    function sortPosts(order) {
      const cards = Array.from(grid.querySelectorAll('.post-card'));
      
      // Sort the DOM elements based on the data-date attribute
      cards.sort((a, b) => {
        const dateA = parseInt(a.dataset.date);
        const dateB = parseInt(b.dataset.date);
        return order === 'newest' ? dateB - dateA : dateA - dateB;
      });
      
      // Re-append elements to the grid in the new order
      cards.forEach(card => grid.appendChild(card));

      // Update active button styling by querying the CURRENT buttons in the DOM
      document.querySelectorAll('.sort-btn').forEach(btn => {
        if (btn.dataset.sort === order) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Update URL silently without reloading the page
      const newUrl = new URL(window.location);
      newUrl.searchParams.set('sort', order);
      window.history.replaceState({}, '', newUrl);
    }

    // Apply initial sort if needed
    if (initialSort === 'oldest') {
      sortPosts('oldest');
    }

    // Add click listeners to the buttons
    document.querySelectorAll('.sort-btn').forEach(btn => {
      // Clone and replace to prevent duplicate event listeners from ViewTransitions
      const newBtn = btn.cloneNode(true);
      btn.replaceWith(newBtn);
      
      newBtn.addEventListener('click', () => {
        sortPosts(newBtn.dataset.sort);
      });
    });
  }

  // Run on initial load and after Astro ViewTransitions
  document.addEventListener('astro:page-load', setupSorting);
</script>